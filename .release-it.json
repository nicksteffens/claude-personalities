{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "github": {
    "release": true
  },
  "npm": false,
  "plugins": {
    "@release-it/bumper": {
      "in": "package.json",
      "out": [
        "package.json",
        ".claude-plugin/plugin.json",
        ".claude-plugin/marketplace.json"
      ]
    }
  }
}
